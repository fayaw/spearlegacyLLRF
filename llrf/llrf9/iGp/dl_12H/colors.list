# Error summary: 0 - green, 1 - yellow, 2 - red
rule 80 "errsum" {
 >=-0.5 && <0.5	 : "green"
 >=0.5  && <1.5	 : "yellow"
 >=1.5  && <=2.5 : "red"
}

# Bicolor LED
rule 81 "led" {
 >=-0.5 && <0.5	 : "green"
 >=0.5  && <1.5	 : "red"
}

# Inverted bicolor LED
rule 82 "nled" {
 >=-0.5 && <0.5	 : "red"
 >=0.5  && <1.5	 : "green"
}
