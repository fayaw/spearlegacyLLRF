usage() {
  echo "Usage: $1 [SYSTEM]"
  echo "  [SYSTEM]      - IOC device name, defaults to LLRF"
  
  exit 1
}

script=`basename $0`
caget=${IGPTOP}/bin/${HOST_ARCH}/caget

if [ -n "$1" ]; then
  sys=$1;
else
  sys=LLRF;
fi

cd ${IGPTOP}/dl_llrf
${IGPTOP}/bin/${HOST_ARCH}/edm -cmap -x -noedit -m "data=.,sys=$sys" top.edl
