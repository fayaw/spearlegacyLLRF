            LLRF1_VS["Vector Sum"]
            LLRF1_WF["Waveforms"]
        end
        
        subgraph llrf2_group["LLRF2: (Unit 2 - Monitoring)"]
            LLRF2_MON["Monitoring"]
            LLRF2_RP["Reflected Power"]
