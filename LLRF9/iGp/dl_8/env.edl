# (X-Y Graph)
object xyGraphClass
beginObjectProperties
major 4
minor 3
release 0
# Geometry
x 590
y 40
w 280
h 200
# Appearance
border
graphTitle "Chassis (green), EXT1 (blue), EXT2 (red)"
xLabel "Time (s)"
yLabel "deg C"
fgColor index 15
bgColor index 79
gridColor index 5
font "helvetica-bold-r-12.0"
# Operating Modes
plotMode "plotLastNPts"
nPts 300
triggerPv "$(sys):$(dev):POLL:TRIG"
# X axis properties
showXAxis
xAxisSrc "fromUser"
xMin 0
xMax 300
# Y axis properties
showYAxis
yAxisSrc "AutoScale"
yMax 1
# Y2 axis properties
y2AxisSrc "AutoScale"
y2Max 1
# Trace Properties
numTraces 3
yPv {
  0 "$(sys):$(dev):TEMP:AMB"
  1 "$(sys):$(dev):TEMP:EXT1"
  2 "$(sys):$(dev):TEMP:EXT2"
}
lineThickness {
  0 2
  1 2
  2 2
}
plotUpdateMode {
  0 "y"
  1 "y"
  2 "y"
}
ySigned {
  0 1
  1 1
  2 1
}
plotColor {
  0 index 28
  1 index 35
  2 index 23
}
endObjectProperties

