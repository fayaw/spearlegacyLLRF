# (X-Y Graph)
object xyGraphClass
beginObjectProperties
major 4
minor 3
release 0
# Geometry
x 10
y 40
w 280
h 200
# Appearance
border
graphTitle "FPGA core supply voltage"
xLabel "Time (s)"
yLabel "V"
fgColor index 15
bgColor index 79
gridColor index 5
font "helvetica-bold-r-12.0"
# Operating Modes
plotMode "plotLastNPts"
nPts 300
triggerPv "$(sys):$(dev):POLL:TRIG"
# X axis properties
showXAxis
xAxisSrc "fromUser"
xMin 0
xMax 300
# Y axis properties
showYAxis
yAxisSrc "AutoScale"
yMin 1.3
yMax 1.7
# Y2 axis properties
y2AxisSrc "AutoScale"
y2Max 1
# Trace Properties
numTraces 1
yPv {
  0 "$(sys):$(dev):VINT"
}
lineThickness {
  0 2
}
plotUpdateMode {
  0 "y"
}
ySigned {
  0 1
}
plotColor {
  0 index 23
}
endObjectProperties

