# (X-Y Graph)
object xyGraphClass
beginObjectProperties
major 4
minor 6
release 0
# Geometry
x 360
y 240
w 350
h 200
# Appearance
border
graphTitle "Averaged spectrum"
xLabel "Frequency (kHz)"
yLabel "dB"
fgColor index 15
bgColor index 79
gridColor index 5
font "helvetica-bold-r-12.0"
# Operating Modes
nPts 1
# X axis properties
showXAxis
xAxisSrc "AutoScale"
xMin 0
xMax 1250
# Y axis properties
showYAxis
yAxisSrc "AutoScale"
yMin -30
yMax 80
# Y2 axis properties
y2AxisSrc "AutoScale"
y2Max 1
# Trace Properties
numTraces 3
xPv {
  0 "$(sys):$(dev):FREQ"
  1 "$(sys):$(dev):VEC:PEAKFREQ1"
  2 "$(sys):$(dev):VEC:PEAKFREQ2"
}
yPv {
  0 "$(sys):$(dev):SPEC"
  1 "$(sys):$(dev):VEC:PEAK1"
  2 "$(sys):$(dev):VEC:PEAK2"
}
plotStyle {
  1 "point"
  2 "point"
}
lineThickness {
  1 2
  2 2
}
plotUpdateMode {
  0 "xOrY"
  1 "xOrY"
}
plotSymbolType {
  1 "circle"
  2 "square"
}
ySigned {
  0 1
  1 1
  2 1
}
plotColor {
  0 index 35
  1 index 23
  2 index 46
}
endObjectProperties

